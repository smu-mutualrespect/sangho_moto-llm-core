{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "medium",
            "reasoningSummary": "auto"
          },
          "variants": {
            "fast": {
              "reasoningEffort": "low",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "careful": {
              "reasoningEffort": "high",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    }
  },
  "agent": {
    "moto-fallback": {
      "description": "Single agent for implementing Moto LLM fallback behavior from README experiment commands.",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./moto/core/llm_agents/agent.md}",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "ask",
        "webfetch": "ask",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls *": "allow",
          "rg *": "allow",
          "sed *": "allow",
          "git status *": "allow",
          "git diff *": "allow",
          "python3 -m pytest *": "allow"
        }
      }
    }
  }
}
