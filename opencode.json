{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "variants": {
            "fast": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "careful": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    }
  },
  "agent": {
    "moto-fallback": {
      "description": "Decision agent for Moto AWS honeypot fallback runtime.",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./moto/core/llm_agents/opencode_agent.md}",
      "temperature": 0.1,
      "steps": 6,
      "permission": {
        "edit": "deny",
        "webfetch": "deny",
        "bash": "deny"
      }
    }
  }
}
